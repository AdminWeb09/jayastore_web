<!doctype html>
<html lang="id" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Toko Pulsa &amp; Kuota</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Plus Jakarta Sans', sans-serif; }
    .glass { background: rgba(255,255,255,0.08); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.1); }
    .card-hover { transition: transform 0.2s, box-shadow 0.2s; }
    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.3); }
    .fade-in { animation: fadeIn 0.4s ease-out; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
    .provider-badge { display: inline-flex; align-items: center; gap: 4px; padding: 2px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .toast-container { position: fixed; top: 20px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
    .toast { padding: 12px 20px; border-radius: 12px; color: #fff; font-size: 14px; font-weight: 500; animation: slideIn 0.3s ease-out; }
    @keyframes slideIn { from { opacity:0; transform:translateX(40px); } to { opacity:1; transform:translateX(0); } }
  </style>
  <style>body { box-sizing: border-box; }</style>
 </head>
 <body class="h-full bg-[#0a0e1a] text-white overflow-auto">
  <div id="app" class="w-full h-full">
   <!-- Toast Container -->
   <div id="toast-container" class="toast-container"></div><!-- STOREFRONT VIEW -->
   <div id="storefront" class="w-full min-h-full" style="display:block;">
    <!-- Header -->
    <header class="w-full px-4 py-6 text-center relative" style="background: linear-gradient(135deg, #1a1f3a 0%, #0d1225 100%);">
     <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 30% 40%, #6366f1 0%, transparent 60%), radial-gradient(circle at 70% 60%, #06b6d4 0%, transparent 60%);"></div>
     <div class="relative z-10 max-w-lg mx-auto">
      <div class="inline-flex items-center gap-2 mb-2 px-4 py-1 rounded-full text-xs font-semibold tracking-wider" style="background: rgba(99,102,241,0.2); color: #a5b4fc;">
       ⚡ TERPERCAYA &amp; MURAH
      </div>
      <h1 id="shop-title" class="text-3xl font-extrabold mb-1" style="background: linear-gradient(90deg, #c7d2fe, #67e8f9); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Toko Pulsa Digital</h1>
      <p id="shop-tagline" class="text-sm text-slate-400">Pulsa &amp; Kuota Murah, Proses Cepat 24 Jam</p>
     </div><!-- Admin toggle --> <button onclick="goToLogin()" class="absolute top-4 right-4 z-20 p-2 rounded-lg text-slate-500 hover:text-slate-300 transition" title="Admin"> <i data-lucide="settings" style="width:18px;height:18px;"></i> </button>
    </header><!-- Filter Tabs -->
    <div class="w-full px-4 py-3 flex gap-2 overflow-x-auto max-w-2xl mx-auto" id="filter-tabs">
     <button onclick="filterProducts('all')" class="filter-btn px-4 py-2 rounded-full text-xs font-semibold whitespace-nowrap transition" data-filter="all" style="background:#6366f1;color:#fff;">Semua</button> <button onclick="filterProducts('pulsa')" class="filter-btn px-4 py-2 rounded-full text-xs font-semibold whitespace-nowrap transition" data-filter="pulsa" style="background:rgba(255,255,255,0.08);color:#94a3b8;">Pulsa</button> <button onclick="filterProducts('kuota')" class="filter-btn px-4 py-2 rounded-full text-xs font-semibold whitespace-nowrap transition" data-filter="kuota" style="background:rgba(255,255,255,0.08);color:#94a3b8;">Kuota</button>
    </div><!-- Product Grid -->
    <div id="product-grid" class="w-full px-4 pb-24 max-w-2xl mx-auto">
     <div id="products-list" class="grid grid-cols-1 sm:grid-cols-2 gap-3"></div>
     <div id="empty-store" class="text-center py-16 text-slate-500 hidden">
      <i data-lucide="package" style="width:48px;height:48px;margin:0 auto 12px;opacity:0.4;"></i>
      <p class="font-semibold">Belum ada produk</p>
      <p class="text-sm mt-1">Produk akan ditambahkan oleh admin</p>
     </div>
    </div><!-- WhatsApp CTA -->
    <div class="fixed bottom-0 left-0 right-0 p-4 z-50" style="background: linear-gradient(to top, #0a0e1a 60%, transparent);">
     <div class="max-w-2xl mx-auto">
      <button id="wa-btn" onclick="openWhatsApp()" class="w-full py-3 rounded-2xl font-bold text-sm flex items-center justify-center gap-2 transition hover:brightness-110" style="background: linear-gradient(135deg, #22c55e, #16a34a); color: #fff;"> <i data-lucide="message-circle" style="width:18px;height:18px;"></i> <span>Pesan via WhatsApp</span> </button>
     </div>
    </div>
    <!-- WhatsApp Button -->
    <div class="fixed bottom-4 right-4">
      <a href="https://wa.me/6285851078585" target="_blank" class="p-3 bg-green-500 text-white rounded-full shadow-lg hover:bg-green-600 transition">
        Hubungi Kami di WhatsApp
      </a>
    </div>
   </div><!-- LOGIN PAGE -->
   <div id="login-page" class="w-full h-full flex items-center justify-center p-4" style="display:none;background:linear-gradient(135deg, #0a0e1a 0%, #1a1f3a 100%);">
    <div class="w-full max-w-sm">
     <div class="glass rounded-3xl p-8 fade-in"><!-- Header -->
      <div class="text-center mb-8">
       <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4" style="background:linear-gradient(135deg, #6366f1, #06b6d4);"><i data-lucide="shield-check" style="width:28px;height:28px;color:#fff;"></i>
       </div>
       <h1 class="text-2xl font-bold mb-2">Admin Panel</h1>
       <p class="text-sm text-slate-400">Masukkan username dan password</p>
      </div><!-- Form -->
      <div class="space-y-4 mb-6">
       <div><label class="text-xs text-slate-400 mb-2 block font-semibold">Username</label> <input id="login-username" type="text" placeholder="admin" class="w-full px-4 py-3 rounded-xl bg-slate-800 border border-slate-700 text-sm focus:border-indigo-500 focus:outline-none transition" onkeypress="if(event.key==='Enter') loginAdmin()">
       </div>
       <div><label class="text-xs text-slate-400 mb-2 block font-semibold">Password</label> <input id="login-password" type="password" placeholder="password" class="w-full px-4 py-3 rounded-xl bg-slate-800 border border-slate-700 text-sm focus:border-indigo-500 focus:outline-none transition" onkeypress="if(event.key==='Enter') loginAdmin()">
       </div>
       <p id="login-error" class="text-red-400 text-xs hidden flex items-center gap-1.5"><i data-lucide="alert-circle" style="width:14px;height:14px;"></i> Username atau password salah</p>
      </div><!-- Button --> <button id="login-btn" onclick="loginAdmin()" class="w-full py-3 rounded-xl text-sm font-bold transition flex items-center justify-center gap-2" style="background:linear-gradient(135deg, #6366f1, #4f46e5); color:#fff;"> <i data-lucide="log-in" style="width:16px;height:16px;"></i> Masuk </button> <!-- Back Button --> <button onclick="backToStore()" class="w-full mt-3 py-3 rounded-xl text-sm font-semibold glass hover:bg-white/10 transition"> Kembali </button> <!-- Info -->
      <p class="text-center text-xs text-slate-500 mt-6">Demo: admin / admin</p>
     </div>
    </div>
   </div><!-- ADMIN PANEL -->
   <div id="admin-panel" class="w-full min-h-full" style="display:none;">
    <header class="w-full px-4 py-5 flex items-center justify-between" style="background: linear-gradient(135deg, #1e1b4b 0%, #0d1225 100%);">
     <div class="flex items-center gap-3">
      <button onclick="exitAdmin()" class="p-2 rounded-xl glass hover:bg-white/10 transition"><i data-lucide="arrow-left" style="width:20px;height:20px;"></i></button>
      <div>
       <h2 class="text-lg font-bold">Panel Admin</h2>
       <p class="text-xs text-slate-400">Kelola produk toko</p>
      </div>
     </div><button onclick="showAddForm()" class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-semibold transition" style="background:#6366f1;color:#fff;"> <i data-lucide="plus" style="width:16px;height:16px;"></i> Tambah </button>
    </header><!-- Add/Edit Form -->
    <div id="product-form" class="w-full px-4 py-4 max-w-2xl mx-auto hidden fade-in">
     <div class="glass rounded-2xl p-5">
      <h3 id="form-title" class="font-bold mb-4">Tambah Produk</h3>
      <div class="space-y-3">
       <div>
        <label class="text-xs text-slate-400 mb-1 block">Tipe</label> <select id="f-type" class="w-full px-3 py-2.5 rounded-xl bg-slate-800 border border-slate-700 text-sm focus:border-indigo-500 focus:outline-none"> <option value="pulsa">Pulsa</option> <option value="kuota">Kuota</option> </select>
       </div>
       <div>
        <label class="text-xs text-slate-400 mb-1 block">Provider</label> <select id="f-provider" class="w-full px-3 py-2.5 rounded-xl bg-slate-800 border border-slate-700 text-sm focus:border-indigo-500 focus:outline-none"> <option value="Telkomsel">Telkomsel</option> <option value="Indosat">Indosat</option> <option value="XL">XL</option> <option value="Tri">Tri</option> <option value="Smartfren">Smartfren</option> <option value="Axis">Axis</option> </select>
       </div>
       <div>
        <label class="text-xs text-slate-400 mb-1 block">Nama Produk</label> <input id="f-name" type="text" placeholder="cth: Pulsa 50rb" class="w-full px-3 py-2.5 rounded-xl bg-slate-800 border border-slate-700 text-sm focus:border-indigo-500 focus:outline-none">
       </div>
       <div>
        <label class="text-xs text-slate-400 mb-1 block">Harga (Rp)</label> <input id="f-price" type="number" placeholder="cth: 50000" class="w-full px-3 py-2.5 rounded-xl bg-slate-800 border border-slate-700 text-sm focus:border-indigo-500 focus:outline-none">
       </div>
       <div>
        <label class="text-xs text-slate-400 mb-1 block">Deskripsi (opsional)</label> <input id="f-desc" type="text" placeholder="cth: Masa aktif 30 hari" class="w-full px-3 py-2.5 rounded-xl bg-slate-800 border border-slate-700 text-sm focus:border-indigo-500 focus:outline-none">
       </div>
       <div class="flex gap-2 pt-2">
        <button id="form-submit-btn" onclick="submitProduct()" class="flex-1 py-2.5 rounded-xl text-sm font-semibold transition" style="background:#6366f1;color:#fff;">Simpan</button> <button onclick="hideForm()" class="px-5 py-2.5 rounded-xl text-sm font-semibold glass hover:bg-white/10 transition">Batal</button>
       </div>
      </div>
     </div>
    </div><!-- Admin Product List -->
    <div id="admin-products" class="w-full px-4 py-4 pb-8 max-w-2xl mx-auto">
     <div id="admin-list" class="space-y-2"></div>
     <div id="admin-empty" class="text-center py-16 text-slate-500 hidden">
      <p class="font-semibold">Belum ada produk</p>
      <p class="text-sm mt-1">Klik "Tambah" untuk menambah produk baru</p>
     </div>
    </div>
   </div><!-- Delete Confirmation -->
   <div id="delete-modal" class="fixed inset-0 z-[100] flex items-center justify-center p-4" style="background:rgba(0,0,0,0.7);display:none;">
    <div class="glass rounded-2xl p-6 w-full max-w-xs fade-in text-center">
     <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-3" style="background:rgba(239,68,68,0.15);">
      <i data-lucide="trash-2" style="width:22px;height:22px;color:#ef4444;"></i>
     </div>
     <h3 class="font-bold mb-1">Hapus Produk?</h3>
     <p id="delete-name" class="text-sm text-slate-400 mb-4"></p>
     <div class="flex gap-2">
      <button onclick="confirmDelete()" id="confirm-del-btn" class="flex-1 py-2.5 rounded-xl text-sm font-semibold transition" style="background:#ef4444;color:#fff;">Hapus</button> <button onclick="closeDeleteModal()" class="flex-1 py-2.5 rounded-xl text-sm font-semibold glass hover:bg-white/10 transition">Batal</button>
     </div>
    </div>
   </div>
  </div>
  <script>
  // ===== STATE =====
  let allProducts = [];
  let currentFilter = 'all';
  let editingProduct = null;
  let deletingProduct = null;
  const ADMIN_CREDENTIALS = { username: 'admin', password: 'admin' };

  const providerColors = {
    'Telkomsel': { bg: 'rgba(239,68,68,0.15)', text: '#f87171' },
    'Indosat': { bg: 'rgba(251,191,36,0.15)', text: '#fbbf24' },
    'XL': { bg: 'rgba(59,130,246,0.15)', text: '#60a5fa' },
    'Tri': { bg: 'rgba(168,85,247,0.15)', text: '#c084fc' },
    'Smartfren': { bg: 'rgba(34,197,94,0.15)', text: '#4ade80' },
    'Axis': { bg: 'rgba(236,72,153,0.15)', text: '#f472b6' },
  };

  // ===== DEFAULT CONFIG =====
  const defaultConfig = {
    shop_name: 'Toko Pulsa Digital',
    shop_tagline: 'Pulsa & Kuota Murah, Proses Cepat 24 Jam',
    contact_wa: '08123456789',
    background_color: '#0a0e1a',
    surface_color: '#1a1f3a',
    text_color: '#e2e8f0',
    primary_action_color: '#6366f1',
    secondary_action_color: '#22c55e',
    font_family: 'Plus Jakarta Sans',
    font_size: 14
  };

  // ===== ELEMENT SDK =====
  window.elementSdk.init({
    defaultConfig,
    onConfigChange: async (config) => {
      const c = { ...defaultConfig, ...config };
      document.getElementById('shop-title').textContent = c.shop_name;
      document.getElementById('shop-tagline').textContent = c.shop_tagline;
      document.body.style.backgroundColor = c.background_color;
      document.body.style.color = c.text_color;
      document.body.style.fontFamily = `${c.font_family}, Plus Jakarta Sans, sans-serif`;

      const baseSize = c.font_size || 14;
      document.getElementById('shop-title').style.fontSize = `${baseSize * 2.1}px`;
      document.getElementById('shop-tagline').style.fontSize = `${baseSize * 0.9}px`;

      // Primary action color
      document.querySelectorAll('[data-primary-btn]').forEach(el => {
        el.style.background = c.primary_action_color;
      });

      renderStorefront();
      renderAdminList();
    },
    mapToCapabilities: (config) => {
      const c = { ...defaultConfig, ...config };
      const makeColor = (key) => ({
        get: () => c[key] || defaultConfig[key],
        set: (v) => { c[key] = v; window.elementSdk.setConfig({ [key]: v }); }
      });
      return {
        recolorables: [
          makeColor('background_color'),
          makeColor('surface_color'),
          makeColor('text_color'),
          makeColor('primary_action_color'),
          makeColor('secondary_action_color'),
        ],
        borderables: [],
        fontEditable: {
          get: () => c.font_family || defaultConfig.font_family,
          set: (v) => { c.font_family = v; window.elementSdk.setConfig({ font_family: v }); }
        },
        fontSizeable: {
          get: () => c.font_size || defaultConfig.font_size,
          set: (v) => { c.font_size = v; window.elementSdk.setConfig({ font_size: v }); }
        }
      };
    },
    mapToEditPanelValues: (config) => {
      const c = { ...defaultConfig, ...config };
      return new Map([
        ['shop_name', c.shop_name],
        ['shop_tagline', c.shop_tagline],
        ['contact_wa', c.contact_wa],
      ]);
    }
  });

  // ===== DATA SDK =====
  const dataHandler = {
    onDataChanged(data) {
      allProducts = data;
      renderStorefront();
      renderAdminList();
    }
  };
  (async () => {
    const r = await window.dataSdk.init(dataHandler);
    if (!r.isOk) console.error('Data SDK init failed');
  })();

  // ===== TOAST =====
  function showToast(msg, type = 'success') {
    const c = document.getElementById('toast-container');
    const t = document.createElement('div');
    t.className = 'toast';
    t.style.background = type === 'success' ? '#22c55e' : type === 'error' ? '#ef4444' : '#6366f1';
    t.textContent = msg;
    c.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 2500);
  }

  // ===== FORMAT =====
  function formatRp(n) { return 'Rp ' + Number(n).toLocaleString('id-ID'); }

  // ===== STOREFRONT RENDER =====
  function renderStorefront() {
    const container = document.getElementById('products-list');
    const emptyEl = document.getElementById('empty-store');
    const filtered = currentFilter === 'all' ? allProducts.filter(p => p.active !== false) : allProducts.filter(p => p.type === currentFilter && p.active !== false);

    if (filtered.length === 0) {
      container.innerHTML = '';
      emptyEl.classList.remove('hidden');
      return;
    }
    emptyEl.classList.add('hidden');

    const existingMap = new Map([...container.children].map(el => [el.dataset.pid, el]));
    const newIds = new Set(filtered.map(p => p.__backendId));

    existingMap.forEach((el, id) => { if (!newIds.has(id)) el.remove(); });

    filtered.forEach((p, i) => {
      const existing = existingMap.get(p.__backendId);
      if (existing) {
        updateProductCard(existing, p);
      } else {
        const card = createProductCard(p, i);
        container.appendChild(card);
      }
    });
  }

  function createProductCard(p, i) {
    const div = document.createElement('div');
    div.dataset.pid = p.__backendId;
    div.className = 'card-hover fade-in';
    div.style.animationDelay = `${i * 0.05}s`;
    updateProductCard(div, p);
    return div;
  }

  function updateProductCard(el, p) {
    const pc = providerColors[p.provider] || { bg: 'rgba(255,255,255,0.1)', text: '#94a3b8' };
    const typeIcon = p.type === 'pulsa' ? 'smartphone' : 'wifi';
    el.innerHTML = `
      <div class="glass rounded-2xl p-4 flex items-center gap-4 cursor-pointer" onclick="orderProduct('${p.name}','${formatRp(p.price)}')">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0" style="background:${pc.bg}">
          <i data-lucide="${typeIcon}" style="width:20px;height:20px;color:${pc.text}"></i>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-0.5">
            <span class="font-semibold text-sm truncate">${p.name}</span>
            <span class="provider-badge" style="background:${pc.bg};color:${pc.text}">${p.provider}</span>
          </div>
          ${p.description ? `<p class="text-xs text-slate-400 truncate">${p.description}</p>` : ''}
        </div>
        <div class="text-right shrink-0">
          <p class="font-bold text-sm" style="color:#67e8f9">${formatRp(p.price)}</p>
        </div>
      </div>`;
    lucide.createIcons();
  }

  function filterProducts(f) {
    currentFilter = f;
    document.querySelectorAll('.filter-btn').forEach(btn => {
      const active = btn.dataset.filter === f;
      btn.style.background = active ? '#6366f1' : 'rgba(255,255,255,0.08)';
      btn.style.color = active ? '#fff' : '#94a3b8';
    });
    renderStorefront();
  }

  function orderProduct(name, price) {
    const cfg = { ...defaultConfig, ...window.elementSdk.config };
    const wa = cfg.contact_wa.replace(/\D/g, '');
    const msg = encodeURIComponent(`Halo, saya mau pesan:\n📦 ${name}\n💰 ${price}\n\nMohon diproses ya. Terima kasih!`);
    window.open(`https://wa.me/6285851078585/${wa}?text=${msg}`, '_blank');
  }

  function openWhatsApp() {
    const cfg = { ...defaultConfig, ...window.elementSdk.config };
    const wa = cfg.contact_wa.replace(/\D/g, '');
    window.open(`https://wa.me/6285851078585/${wa}`, '_blank');
  }

  // ===== ADMIN LOGIN =====
  function goToLogin() {
    document.getElementById('storefront').style.display = 'none';
    document.getElementById('login-page').style.display = 'flex';
    document.getElementById('login-username').value = '';
    document.getElementById('login-password').value = '';
    document.getElementById('login-error').classList.add('hidden');
    document.getElementById('login-username').focus();
    lucide.createIcons();
  }

  function backToStore() {
    document.getElementById('login-page').style.display = 'none';
    document.getElementById('storefront').style.display = 'block';
    lucide.createIcons();
  }

  function loginAdmin() {
    const username = document.getElementById('login-username').value.trim();
    const password = document.getElementById('login-password').value;
    const btn = document.getElementById('login-btn');
    const errorMsg = document.getElementById('login-error');

    if (!username || !password) {
      errorMsg.classList.remove('hidden');
      return;
    }

    if (username === ADMIN_CREDENTIALS.username && password === ADMIN_CREDENTIALS.password) {
      errorMsg.classList.add('hidden');
      btn.disabled = true;
      btn.innerHTML = '<i data-lucide="loader" style="width:16px;height:16px;animation:spin 1s linear infinite;"></i> Memuat...';

      setTimeout(() => {
        document.getElementById('login-page').style.display = 'none';
        document.getElementById('admin-panel').style.display = 'block';
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="log-in" style="width:16px;height:16px;"></i> Masuk';
        renderAdminList();
        lucide.createIcons();
      }, 500);
    } else {
      errorMsg.classList.remove('hidden');
      document.getElementById('login-password').value = '';
      document.getElementById('login-password').focus();
    }
  }

  function exitAdmin() {
    document.getElementById('admin-panel').style.display = 'none';
    document.getElementById('storefront').style.display = 'block';
    hideForm();
    renderStorefront();
    lucide.createIcons();
  }

  // ===== ADMIN PRODUCT LIST =====
  function renderAdminList() {
    const container = document.getElementById('admin-list');
    const emptyEl = document.getElementById('admin-empty');

    if (allProducts.length === 0) {
      container.innerHTML = '';
      emptyEl.classList.remove('hidden');
      return;
    }
    emptyEl.classList.add('hidden');

    const existingMap = new Map([...container.children].map(el => [el.dataset.pid, el]));
    const newIds = new Set(allProducts.map(p => p.__backendId));

    existingMap.forEach((el, id) => { if (!newIds.has(id)) el.remove(); });

    allProducts.forEach(p => {
      const existing = existingMap.get(p.__backendId);
      if (existing) {
        updateAdminCard(existing, p);
      } else {
        const card = document.createElement('div');
        card.dataset.pid = p.__backendId;
        card.className = 'fade-in';
        updateAdminCard(card, p);
        container.appendChild(card);
      }
    });
    lucide.createIcons();
  }

  function updateAdminCard(el, p) {
    const pc = providerColors[p.provider] || { bg: 'rgba(255,255,255,0.1)', text: '#94a3b8' };
    const inactive = p.active === false;
    el.innerHTML = `
      <div class="glass rounded-xl p-4 flex items-center gap-3 ${inactive ? 'opacity-50' : ''}">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-0.5">
            <span class="font-semibold text-sm truncate">${p.name}</span>
            <span class="provider-badge" style="background:${pc.bg};color:${pc.text}">${p.provider}</span>
            <span class="provider-badge" style="background:rgba(255,255,255,0.05);color:#64748b">${p.type}</span>
          </div>
          <p class="text-xs text-slate-400">${formatRp(p.price)}${p.description ? ' · ' + p.description : ''}</p>
        </div>
        <div class="flex items-center gap-1 shrink-0">
          <button onclick="toggleActive('${p.__backendId}')" class="p-2 rounded-lg hover:bg-white/10 transition" title="${inactive ? 'Aktifkan' : 'Nonaktifkan'}">
            <i data-lucide="${inactive ? 'eye-off' : 'eye'}" style="width:16px;height:16px;color:${inactive ? '#64748b' : '#4ade80'}"></i>
          </button>
          <button onclick="editProduct('${p.__backendId}')" class="p-2 rounded-lg hover:bg-white/10 transition" title="Edit">
            <i data-lucide="edit" style="width:16px;height:16px;color:#60a5fa"></i>
          </button>
          <button onclick="askDelete('${p.__backendId}')" class="p-2 rounded-lg hover:bg-white/10 transition" title="Hapus">
            <i data-lucide="trash-2" style="width:16px;height:16px;color:#f87171"></i>
          </button>
        </div>
      </div>`;
  }

  // ===== ADD / EDIT FORM =====
  function showAddForm() {
    editingProduct = null;
    document.getElementById('form-title').textContent = 'Tambah Produk';
    document.getElementById('f-type').value = 'pulsa';
    document.getElementById('f-provider').value = 'Telkomsel';
    document.getElementById('f-name').value = '';
    document.getElementById('f-price').value = '';
    document.getElementById('f-desc').value = '';
    document.getElementById('product-form').classList.remove('hidden');
  }

  function editProduct(id) {
    const p = allProducts.find(x => x.__backendId === id);
    if (!p) return;
    editingProduct = p;
    document.getElementById('form-title').textContent = 'Edit Produk';
    document.getElementById('f-type').value = p.type || 'pulsa';
    document.getElementById('f-provider').value = p.provider || 'Telkomsel';
    document.getElementById('f-name').value = p.name || '';
    document.getElementById('f-price').value = p.price || '';
    document.getElementById('f-desc').value = p.description || '';
    document.getElementById('product-form').classList.remove('hidden');
  }

  function hideForm() {
    document.getElementById('product-form').classList.add('hidden');
    editingProduct = null;
  }

  async function submitProduct() {
    const name = document.getElementById('f-name').value.trim();
    const price = parseInt(document.getElementById('f-price').value);
    if (!name || !price) { showToast('Nama dan harga wajib diisi', 'error'); return; }

    const btn = document.getElementById('form-submit-btn');
    btn.disabled = true; btn.textContent = 'Menyimpan...';

    const data = {
      type: document.getElementById('f-type').value,
      provider: document.getElementById('f-provider').value,
      name,
      price,
      description: document.getElementById('f-desc').value.trim(),
      active: true
    };

    let result;
    if (editingProduct) {
      result = await window.dataSdk.update({ ...editingProduct, ...data });
    } else {
      if (allProducts.length >= 999) {
        showToast('Batas maksimum 999 produk tercapai', 'error');
        btn.disabled = false; btn.textContent = 'Simpan';
        return;
      }
      result = await window.dataSdk.create(data);
    }

    btn.disabled = false; btn.textContent = 'Simpan';

    if (result.isOk) {
      showToast(editingProduct ? 'Produk diperbarui!' : 'Produk ditambahkan!');
      hideForm();
    } else {
      showToast('Gagal menyimpan produk', 'error');
    }
  }

  // ===== TOGGLE ACTIVE =====
  async function toggleActive(id) {
    const p = allProducts.find(x => x.__backendId === id);
    if (!p) return;
    const result = await window.dataSdk.update({ ...p, active: p.active === false ? true : false });
    if (result.isOk) showToast(p.active === false ? 'Produk diaktifkan' : 'Produk dinonaktifkan', 'info');
  }

  // ===== DELETE =====
  function askDelete(id) {
    deletingProduct = allProducts.find(x => x.__backendId === id);
    if (!deletingProduct) return;
    document.getElementById('delete-name').textContent = deletingProduct.name;
    document.getElementById('delete-modal').style.display = 'flex';
    lucide.createIcons();
  }

  function closeDeleteModal() {
    document.getElementById('delete-modal').style.display = 'none';
    deletingProduct = null;
  }

  async function confirmDelete() {
    if (!deletingProduct) return;
    const btn = document.getElementById('confirm-del-btn');
    btn.disabled = true; btn.textContent = 'Menghapus...';
    const result = await window.dataSdk.delete(deletingProduct);
    btn.disabled = false; btn.textContent = 'Hapus';
    if (result.isOk) {
      showToast('Produk dihapus');
      closeDeleteModal();
    } else {
      showToast('Gagal menghapus', 'error');
    }
  }

  // Init icons
  lucide.createIcons();
</script>
